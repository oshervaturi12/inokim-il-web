6 60 60 60zm0-100c22.056 0 40 17.944 40 40s-17.944 40-40 40-40-17.944-40-40 17.944-40 40-40z"></path></g></g></svg>
                            </button>
                            </form>

                        <% } %>

                        <div id="cart-sum">
                            <h2 class="nice-title" style="font-size: 1.5em;">סיכום ההזמנה</h2>

                            <% 
                                let rawTotal = 0;
                                cart.items.forEach(item => {
                                    rawTotal += (item.price || 0) * (item.quantity || 1);
                                   
                                });
                                %>
        
                            <ul>
                                <li>
                                    <span>מוצרים</span>
                                    <span id="products"> <%=  formatter.format(rawTotal)  %>  </span>
                                </li>
        
                                <% if(cart.coupon) { %>
                                    <li>
                                        <span>קופון</span>
                                        <span> <%= (cart.coupon.code)  %>  </span>
                                     
                                    </li>
                               <% } %>
                                
                                
                                <li>
                                    <span>משלוח</span>
                                    <span>
                                        <span id="del-price">איסוף עצמי</span>
                                    </span>
                                </li>
                                <li class="total">
                                    <span>סך הכל</span>
        
                                    
                                    <span>
