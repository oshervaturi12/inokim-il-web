            data-ab-test="home.hero"
          >
            <%= home.hero.buttonText %>
          </a> 

            <a class="me-2 bg-danger text-white"
            href="<%= home.hero.buttonLink %>/overview" 
            data-ab-test="home.hero"
          >
           מידע נוסף
          </a> 


          </div>

        <% } %>

      </div>
    </section>
    
    <% if(!noVAT) { %>

    <section class="home-prd">
      <div class="container">
        <div class="our-team">
          <div class="text"> <%= home.productHighlightsTitle%> </div>

          <div class="d-none d-md-block">
            <%- optimizeImage(`${home.productHighlightsImage}`, 'קולקציית אינוקים', 'img-fluid') %>
          </div>


          <div class="d-block d-md-none">
             <%- optimizeImage(`/optimized/test.png`, 'קולקציית אינוקים', 'img-fluid') %>
          </div>
        


        </div>
      </div>
        <div class="items d-none d-md-flex">
          <% home.productHighlights.forEach(product => { %>
            <div class="item">
              <div class="icon"><%- product.iconSvg %></div>
              <div class="line">
                <span>
                  <span data-bs-toggle="tooltip" data-bs-title="עד <%= product.range  %> ק״מ ט.ל.ח">*טווח</span>
                <span><%= product.range %></span>
              </span>
                <span class="divider-line">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 23.85 53.77"><path stroke="#000" stroke-width="2" d="m22.92.38-22 53" data-name="Line 5"></path></svg>
                </span>
                <span><span>מהירות</span><span><%= product.speed %></span></span>
              </div>
              <div class="w-100 d-flex align-items-center gap-3">
                <a href="/products/<%= product.productSlug %>">קנה עכשיו</a>
                <a href="/products/<%= product.overviewSlug %>" class="black">מידע נוסף</a>
              </div>
            </div>
          <% }) %>
        </div>
     
     
    </section>


    <%- include('./partials/inokim-swiper-init')  %>


   <% } %>
  


