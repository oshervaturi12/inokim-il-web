<%- include("./partials/navbar.ejs", { customClass: customClass }) %>




<div id="blog-banner">

    <header class="banner">

        <div class="img">
            <picture>
                <!-- <source media="(max-width: 720px)" srcset="/optimized/bg-overview.png" type="image/webp">
                <source srcset="/optimized/bg-overview.png" type="image/webp">
                <source media="(max-width: 720px)" srcset="/optimized/bg-overview.png">
                <img alt="" src="/optimized/bg-overview.png"> -->
            </picture>
        </div>

        <div class="container">
            <ul class="list-of-items">
                <li>פורסם: <time class="me-1"> <%= blog.publishedAt.toLocaleDateString('he-IL')  %> </time></li>
                <li>
                    <svg viewBox="0 -10 511.987 511" xmlns="http://www.w3.org/2000/svg"><path d="M510.652 185.902a27.158 27.158 0 0 0-23.425-18.71l-147.774-13.419-58.433-136.77C276.71 6.98 266.898.494 255.996.494s-20.715 6.487-25.023 16.534l-58.434 136.746-147.797 13.418A27.208 27.208 0 0 0 1.34 185.902c-3.371 10.368-.258 21.739 7.957 28.907l111.7 97.96-32.938 145.09c-2.41 10.668 1.73 21.696 10.582 28.094 4.757 3.438 10.324 5.188 15.937 5.188 4.84 0 9.64-1.305 13.95-3.883l127.468-76.184 127.422 76.184c9.324 5.61 21.078 5.097 29.91-1.305a27.223 27.223 0 0 0 10.582-28.094l-32.937-145.09 111.699-97.94a27.224 27.224 0 0 0 7.98-28.927zm0 0" fill="#ffc107"></path></svg>
                    5.0                </li>
                <li>2 דקות</li>
            </ul>
        </div>

    </header>

</div>

<main class="pt-2 pb-4">

    <div class="container">

        <%- include('./partials/breadcrumbs', { breadcrumbs }) %>

        <div class="row align-items-start">

            <aside class="col-12 col-xl-3" id="blog-side">

                <div class="_bo ps-2">

                    <% if (blog.tableOfContents && blog.tableOfContents.length) { %>
                        <div id="table-of-contents">
                          <strong>תוכן עניינים</strong>
                          <ol>
                            <% blog.tableOfContents.forEach(item => { %>
                              <li>
                                <a href="#<%= item.anchor %>"><%= item.label %></a>
                              </li>
                            <% }) %>
                          </ol>
                        </div>
                      <% } %>
                      
                    
                    

<div class="inokim-ad">

    <%- optimizeImage(blog.coverImage, blog.title, 'loaded') %>



    <a href="/contact-us" class="btn btn-light mt-2 w-100">דברו איתנו</a>

</div>
                </div>


            </aside>

            <main class="col-12 col-xl-9 nice-content">
               <h1 class="mb-5"><%- blog.title  %></h1>

               <%- blog.content %> 
      

       

                
                <h2 class="mb-3">שווה לקרוא</h2>

                    <div class="row g-2">
                    <% relatedPosts.forEach(post => { %>
                        <div class="col-12 col-sm-6 col-md-6 col-lg-4 mb-3">
                        <div class="item-post">
                            <header class="header">
                            <a href="/blog/<%= post.slug %>" tabindex="-1" aria-label="תמונה של <%= post.title %>">

                                <%- optimizeImage(post.coverImage, blog.title, 'card-img-top loaded') %>
                          
                            </a>
                            </header>
                            <section class="body">
                            <h3 class="mb-1 mt-2"><a href="/blog/<%= post.slug %>"><%= post.title %></a></h3>
                            <ul class="list-of-items mb-2">
                                <li><time><%= new Date(post.publishedAt).toLocaleDateString('he-IL') %></time></li>
                            </ul>
                            <p class="text-muted"><%= post.excerpt %></p>
                            </section>
                        </div>
                        </div>
                    <% }); %>
                    </div>




            </main>


    </div>

</main>

</div>
<%- include("./partials/footer.ejs") %>
