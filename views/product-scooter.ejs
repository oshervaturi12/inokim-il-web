  <style>

.sticky-bottom {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.sticky-benefits {
  display: flex;
  justify-content: center;
  gap: 8px;
  direction: rtl;
  flex-wrap: wrap;
}

.sticky-benefits span {
  display: inline-flex;
  align-items: center;
  gap: 5px;
}

.sticky-benefit-icon {
  width: 15px;
  height: 15px;
  flex-shrink: 0;
}

.sticky-benefits span {
  padding: 5px 10px;
  border-radius: 8px;
  background: rgba(0, 0, 0, 0.06);
  color: #111;
  font-size: 12px;
  font-weight: 700;
  white-space: nowrap;
}

.sticky-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  width: 100%;
}

.sticky-actions .price-section {
  flex: 1;
}

.sticky-actions .btn-add-to-cart {
  width: 50%;
}

@media (max-width: 767px) {
  .sticky-benefits {
    gap: 6px;
  }

  .sticky-benefits span {
    font-size: 11px;
    padding: 5px 8px;
  }
} 

.feature-card--app {
  grid-column: 1 / -1;
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 14px;
  padding: 18px 18px 16px;
  border-radius: 18px;
  overflow: hidden;
  isolation: isolate;
}



/* Ambient glow */
.feature-card__glow {
  position: absolute;
  inset: -40% -20% auto auto;
  width: 320px;
  height: 320px;
  background: radial-gradient(closest-side, rgba(80, 160, 255, 0.28), transparent 70%);
  filter: blur(8px);
  z-index: -1;
  pointer-events: none;
  animation: kixGlow 7s ease-in-out infinite alternate;
}

@keyframes kixGlow {
  0%   { transform: translate(0, 0) scale(1); opacity: .85; }
  100% { transform: translate(-20px, 20px) scale(1.08); opacity: 1; }
}

/* Header row */
.feature-card__head {
  display: flex;
  align-items: center;
  gap: 12px;
}

.feature-card__icon {
  flex: 0 0 auto;
  width: 38px;
  height: 38px;
  display: grid;
  place-items: center;
  border-radius: 12px;
  background: linear-gradient(135deg, #2C2C2E, #1A1A1C);
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: #5AC8FA;
  box-shadow: 0 4px 12px rgba(90, 200, 250, 0.18);
}

.feature-card__title-wrap {
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 0;
  flex: 1;
}

.feature-card__title-wrap strong {
  font-size: 15px;
  font-weight: 700;
  color: #fff;
  letter-spacing: -0.01em;
}

.feature-card__title-wrap span {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 500;
}


/* Feature list */
.feature-card__list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px 14px;
}

.feature-card__list li {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12.5px;
  font-weight: 500;
  color: #000;
  line-height: 1.35;
}

.feature-card__list li svg {
  flex: 0 0 auto;
  width: 14px;
  height: 14px;
  padding: 2px;
  border-radius: 50%;
  background: rgba(90, 200, 250, 0.15);
}

/* CTA */
.feature-card__cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 12px 16px;
  border-radius: 8px;
  background: #fff;
  color: #000;
  font-size: 13.5px;
  font-weight: 600;
  text-decoration: none;
  letter-spacing: -0.01em;
  margin-top: 2px;
  width: 100% !important;
}

.feature-card__cta:hover {
  background: #f2f2f2;
  transform: translateY(-1px);
}

.feature-card__cta:active {
  transform: translateY(0);
}

/* In RTL the visual back-arrow should point right */
.feature-card__cta-arrow {
  transform: scaleX(-1);
  transition: transform .2s ease;
}

.feature-card__cta:hover .feature-card__cta-arrow {
  transform: scaleX(-1) translateX(-3px);
}

/* Mobile */
@media (max-width: 480px) {
  .feature-card--app {
    padding: 16px;
  }

     .product-details svg {
     width: 100% !important;
    }

    .feature-card__cta svg{
              width: 3em !important;
    }

  .feature-card__list {
    grid-template-columns: 1fr;
  }

  .feature-card__title-wrap strong { font-size: 14px; }
  .feature-card__title-wrap span   { font-size: 11.5px; }
}

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
  .feature-card--app,
  .feature-card__cta,
  .feature-card__cta-arrow,
  .feature-card__glow {
    transition: none;
    animation: none;
  }


}</style>


