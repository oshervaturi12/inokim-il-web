<% if (announcement && announcement.text && announcement.text.trim() !== "") { %>
  <%- include("./partials/announcement.ejs", { 
    text: announcement.text,
    buttonLink: announcement.buttonLink || null,
    buttonText: announcement.buttonText || null,
    isSale: true
  }) %>
<% } %>

<%- include("./partials/navbar.ejs", { customClass: customClass }) %>


<main class="product-page">
    <div class="product-container">
      <!-- Right Column (Gallery) -->
      <div class="product-gallery" id="p-gallery">
        <section class="splide" aria-label="Product Images">
          <div class="splide__track">
            <ul class="splide__list" style="max-height: 100%;">
              <% if (product && product.variants.length > 0 ) { %>
                <% product.variants[0].gallery.forEach((img, index) => { %>
                  <li class="splide__slide">
                      <div class="slide-image-wrapper">
                        <img src="<%= `${s3path}${img.replaceAll('/img', "/optimized")}` %>" alt="<%= product.title %> - <%= index + 1 %>">
                      </div>
                    </li>
                  <% }) %>
                  <% } else { %>
                     <% product.gallery.forEach((img, index) => { %>
                     <li class="splide__slide">
                    <div class="slide-image-wrapper">
                      <img src="<%= `${s3path}${img.replaceAll('/img', "/optimized")}` %>" alt="<%= product.title %> - <%= index + 1 %>">
                    </div>
                  </li>
                  <% }) %>
                 <% } %>

            </ul>
          </div>
        </section>
      </div>

  
      <!-- Left Column (Product Content) -->
      <div class="product-details <%= announcement && announcement.text && announcement.text.trim() !== "" ? "custom-heigth": ""  %>" id="product-options-container">
        <div class="border-bottom text-center product-header mb-3 p-2">
          <%- product.logoSvg %>
          <h1> <%= product.title  %> </h1>
      
        </div>

        <div class="product-specs-group">
          <% if(product && product.mainInfo.length > 0) { %>

            <% product.mainInfo.forEach(info =>{ %>
              <div>
                <span class="spec-item"><%= info.value  %></span>
                <span><%= info.key  %> </span>
              </div>
           <% }) %>

         <% } %>
      
        </div>
  




