        <% if (product && product.variants.length > 0) { %>
        <div class="choose-model mb-3" data-id="<%= product._id  %>">
   
            <% product.variants.forEach((prd, index) => { 
                const outOfStock = prd.availability === "אזל במלאי";
                const isPreOrder = prd.isPreOrder === true;
              %>

              <div
                class="d-flex justify-content-between align-items-center border rounded mb-3 item-model"
                style="<%= outOfStock ? 'pointer-events: none; opacity: 0.6;' : '' %>"
                data-index="<%= index %>"
                data-colors="<%= encodeURIComponent(JSON.stringify(prd.colors)) %>"
                data-gallery="<%= encodeURIComponent(JSON.stringify(prd.gallery || [])) %>"
                data-price="<%= prd.colors[0].price %>"
                data-compare-at-price="<%= prd.colors[0].compareAtPrice || prd.colors[0].price %>"
                data-submodel="<%= prd.subModel %>"
                data-id="<%= prd._id %>"
                data-sku="<%= prd.colors[0].sku || prd._id  %>"
                data-availability="<%= prd.availability %>"
              >
                <span class="d-flex flex-wrap"><%= prd.subModel %>
                    <% if(outOfStock) { %>
                  <span class="ms-2 badge bg-danger">אזל במלאי</span>
                <% } %>

              <% if(isPreOrder) { %>
                  <div class="me-2 d-flex justify-content-center align-items-center badge bg-warning text-dark" id="test">מכירה מוקדמת</div>
                <% } %>

                   <% if(noVAT) { %>
                  <span class="me-3 badge bg-danger">ללא מע״מ</span>
                  <% } %>   
                       <% if(product.label) { %>
                         <span class="me-3 badge bg-danger"> <%= product.label %> </span>
                      <% } %>
                  </span>
                <span>
                  <%=  formatter.format(  prd.colors[0].price) %>
                  <% if(prd.colors[0].compareAtPrice && prd.colors[0].compareAtPrice > prd.colors[0].price ) { %>
                    <strike class="me-2"> <%=  formatter.format( prd.colors[0].compareAtPrice) %> </strike>
                 <% } %>
                </span>
              </div>

            <% }); %>

