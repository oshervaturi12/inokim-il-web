                  </div>
                <% } %>
        
                <div class="d-flex upsale justify-content-between align-items-center border rounded mb-3 item-upsale"
                  data-upsellid="<%= up._id %>"
                  data-price="<%= up.customPrice %>"
                  data-name="<%= up.customTitle %>"
                  >
                  <span><%= up.customTitle %></span>
                  <span><%= formatter.format(up.customPrice) %></span>
                </div>
        
                <% if (up.customVideo || up.customImage) { %>
                  
                  <div class="d-flex align-items-center justify-content-between border rounded mb-3" data-bs-toggle="modal" data-bs-target="#videoUpsellProduct">
                    <% if (up.customImage) { %>
                      <div class="image-cyborg">
                        <img src="<%= `${s3path}${up.customImage}` %>" alt="">
                      </div>
                    <% } %>
                    <% if (up.customVideo) { %>
                      <div class="px-3 cursor-pointer">
                        <div class="d-flex flex-column align-items-start">
                          <strong>צפה בוידאו</strong>
                          <span>גלה איך זה נראה על הכביש</span>
                        </div>
                      </div>
                    <% } %>
                  </div>
        
                  <% if (up.customVideo) { %>
                    <%- include("./partials/modals/upsellVideo.ejs", { name: up.product?.name || '', video: up.customVideo, svg:  up.customSvg, s3path}) %>
                  <% } %>
                <% } %>
        
              <% } else if (up.categoryUpsell === 2) { %>
                <% accessories.push(up); %>
              <% } else if(false) { %>

                    <div class="mb-3" id="palletSelection">
                    <h2>בחירת פלטה מעוצבת</h2>

                    <div class="d-flex align-items-center border rounded mb-3 text-end" data-bs-toggle="modal" data-bs-target="#palletGridModal">
                      <div class="image-cyborg d-flex align-items-center justify-content-center">
                        <img src="https://d3kxrpm9y5cv3a.cloudfront.net<%= up.product.variants[0].colors[0].image  %>" alt="" style="height: auto; width: 40%; transform: rotate(90deg);">
                      </div>
                      <div class="cursor-pointer">
                        <div class="d-flex flex-column align-items-start w-100">
                          <strong>צפה בפלטות</strong> 
                          <span>גלה עיצובים חדשים לאוקס שלך</span>
                        </div>
                      </div>
                    </div>
                    </div>

                    <%-  include('./partials/modals/pallets.ejs', {product:  up.product}) %>
              <% }  %>
          <% }) %>
        
          <% if (accessories.length > 0) { %>
              <div class="accessories-upsell text-center mt-5">
                <h2 class="mb-3">אביזרים נלווים</h2>
        
                <% accessories.forEach(accessory => { %>
                  <div class="d-flex upsale justify-content-between align-items-center border rounded mb-3 item-upsale"
                    data-upsellid="<%= accessory._id %>"
                    data-price="<%= accessory.customPrice %>"
                    data-name="<%= accessory.customTitle %>"
                    >
                    <span><%= accessory.customTitle %></span>
                    <span><%= formatter.format(accessory.customPrice) %></span>
                  </div>
                <% }) %>
              </div>
          <% } %>
        
              </div> 
        <% } %>
        



