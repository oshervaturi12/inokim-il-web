<section class="kix-safety-section position-relative text-start text-light d-flex align-items-center" id="safety-section">
  
  <% 
    const desktopImagePath =  "/optimized/kix-rednder.png";
    const mobileImagePath = "/optimized/kix-render-mobile.png"; 
  %>

  <img 
    src="<%= desktopImagePath %>" 
    alt="<%= product.name %> Safety" 
    class="bg-img d-none d-lg-block"
  >

  <img 
    src="<%= mobileImagePath %>" 
    alt="<%= product.name %> Safety Mobile" 
    class="bg-img d-block d-lg-none"
  >


  <div class="container position-relative z-2 mb-auto mb-md-0 py-5 px-4">
    <div class="row justify-content-start">
      <div class="col-lg-5 col-md-10">
        <div class="safety-content text-end">

          <h2 class="mb-3 fade-up">בטחון בכל נסיעה.</h2>
          <p>
            בטיחות בכל צעד. מערכת מתלים כפולה מתקדמת, בלמים .מדויקים ושלדה מחוזקת — כדי שתישאר בשליטה, תמיד
          </p>

          <div class="safety-slides">
            <div class="safety-slide active">
              <h4 class="text-danger mt-4 mb-2">בלמים איכותיים</h4>
              <p>מערכת בלימה כפולה עם דיוק מקסימלי ותגובה מידית.</p>
            </div>


            <div class="safety-slide">
              <h4 class="text-danger mt-4 mb-2">שלדה מחוזקת</h4>
              <p>מבנה קרבון תעשייתי קל וחזק ששומר על יציבות מלאה.</p>
            </div>

            <div class="safety-slide">
              <h4 class="text-danger mt-4 mb-2">תאורה חכמה</h4>
              <p>תאורת LED קדמית ואחורית שמסתנכרנת עם תנאי הדרך.</p>
            </div>

          </div>

        </div>
      </div>
    </div>
  </div>
</section>


<% if (showCompareSection) { %>
<section class="compare-section py-5 text-center text-dark" id="order">
  <div class="container">
    <h2 class="mb-2">עוצמה קומפקטית. חופש עירוני.</h2>
    <p class="text-secondary mb-5">
      אותו ה-DNA. תג מחיר קטן יותר. הכניסה המושלמת לעולם של Inokim.
    </p>

    <div class="row align-items-center justify-content-center g-4">

      <div class="col-md-4 text-center mobile-hide">
        <img src="https://d3kxrpm9y5cv3a.cloudfront.net/optimized/ox-support.avif" alt="Inokim OX" class="img-fluid mb-3 compare-scooter">
      </div>

      <div class="col-md-4">
        <div class="d-flex gap-5 justify-content-center mb-4" style="height: 3em;">
          <img src="/optimized/ox-logo.png" alt="Inokim OX Logo">
          <img src="/optimized/kix-logo.png" alt="Inokim KIX Logo">
        </div>
        <table class="table table-borderless text-center align-middle compare-table mx-auto">

          <tbody>
            <tr>
              <td class="fw-semi-bold">29 ק"ג</td>
              <td class="text-muted">משקל</td>
              <td><%= weight.replace(' קילו', '').replace('ק״ג בלבד', '').trim() %></td>
            </tr>
            <tr>
              <td class="fw-semi-bold">עד 60 ק״מ</td>
              <td class="text-muted">טווח נסיעה</td>
              <td><%= range%></td>
            </tr>
            <tr>
              <td class="fw-semi-bold">LCD Display</td>
              <td class="text-muted">תצוגה</td>
              <td>LCD Display</td>
            </tr>
            <tr>
              <td class="fw-semi-bold">Enhanced Dual+</td>
              <td class="text-muted">מתלים</td>
              <td>Dual</td>
            </tr>
            <tr>
              <td class="fw-semi-bold">החל מ- ₪6,499</td>
              <td class="text-muted">מחיר</td>
              <td>₪<%= price %></td>
            </tr>
          </tbody>
        </table>

        <a href="/products/inokim-kix" class="btn btn-danger rounded-pill px-4 py-2 mt-3">הזמן את <%= product.name %> עכשיו</a>
      </div>
      <div class="col-md-4 text-center">
        <img src="https://d3kxrpm9y5cv3a.cloudfront.net/optimized/kixWhite.jpeg" alt="<%= product.name %>" class="img-fluid mb-3 compare-scooter">
      </div>

    </div>
  </div>
</section>
<% } %>


<section class="specs p-3">
    <div class="container text-white mt-3 py-0 py-md-5">
        <h2 class="mb-4">מפרט <%= product.name %></h2>
      
        <% if (product.specs && product.specs.length > 0) { %>
          <% product.specs.forEach(spec => { %>
            <div class="spec-section pb-4 mb-5">
              <!-- Section Title -->
              <div class="mb-0 mb-md-4">
                <h5 class="m-0"><%= spec.category %></h5>
              </div>
      
              <% if (spec.category === 'מידות' && spec.image) { %>
                <!-- Special Layout for מידות -->
                <div class="row align-items-center">
                  <!-- Spec Items -->
                  <div class="col-12 col-md-8 order-2 order-md-1">
                    <div class="row">
                      <% spec.items.forEach(item => { %>
                        <div class="col-6 col-md-6 d-flex flex-column justify-content-center align-items-start pb-3">
                          <span class="fw-bold mb-2"><%= item.label %></span>
                          <strong><%= item.value %></strong>
                        </div>
                      <% }) %>
                    </div>
                  </div>
      
                  <div class="col-12 col-md-4 text-center order-1 order-md-2">

                  <img src="<%= `${s3path}${spec.image}` %>" alt="<%= spec.category %>" class="img-fluid"> 
                  </div>
                </div>
              <% } else { %>
                <!-- General Layout for Other Specs -->
                <% if (spec.image) { %>
                  <div class="spec-image text-center mb-4">

                  </div>
                <% } %>
      
                <% if (spec.items && Array.isArray(spec.items)) { %>
                  <div class="row">
                    <% spec.items.forEach(item => { %>
                      <div class="col-6 col-md-3 d-flex flex-column justify-content-center align-items-start pb-3">
                        <span class="fw-bold mb-2"><%= item.label %></span>
                        <strong><%= item.value %></strong>
                      </div>
                    <% }) %>
                  </div>
                <% } else { %>
                  <p class="text-center text-muted">לא נמצאו פריטים במפרט זה.</p>
                <% } %>
              <% } %>
            </div>
          <% }) %>
        <% } else { %>
          <p class="text-center text-muted">לא קיימים מפרטים זמינים עבור מוצר זה.</p>
        <% } %>

      </div>
      
    
    
    
</section>




</main>


