<%- include("./partials/announcement.ejs", { 
    text: `קבלו את ה-KIX במחיר השקה מיוחד!`, 
    buttonLink:  `${!hasInventory ? "#secondHand": `/products/${product.slug}`}`  , 
    buttonText: `קנה עכשיו`,
    isSale: false
}) %>

<%- include("./partials/navbar.ejs", { customClass: customClass }) %>
<!-- <div class="hero-bg desktop-bg" style="background-image: url('<%= s3path %><%= product.overviewImage || "/optimized/kix-hero.png" %>');"></div> -->

<%
  
  const mainVariant = product.variants.find(v => v.order === 0) || product.variants[0];
  const mainColor = mainVariant?.colors[0];

  const mainInfoMap = product.mainInfo.reduce((acc, item) => {
    acc[item.key] = item.value;
    return acc;
  }, {});

  const range = mainInfoMap['טווח נסיעה'] || 'N/A';
  const weight = mainInfoMap['משקל'] || 'N/A';
  const price = mainColor?.price || 'N/A';
  
  const chargeTimeSpec = product.specs.find(s => s.category === 'טעינה')?.items.find(i => i.label === 'מהירות טעינה');
  const chargeTime = chargeTimeSpec ? chargeTimeSpec.value.replace(' שעות לטעינה מלאה', '').replace('שעות', '').trim() : 'N/A';

  const showCompareSection = product.templateType === 'kix';
%>

<main id="kix-page">
<section class="hero-section d-flex align-items-center text-end text-dark kix-page" style="height: 100vh; position: relative; margin-top: -4em;">

 <div class="hero-bg desktop-bg"></div>

    <div class="hero-bg mobile-bg"></div>
  
  <div class="container mt-auto mt-md-0">
    <div class="row justify-content-start">
      <div class="col-md-6">
        <div class="hero-content p-3">
          <h6 class="mb-2">הכירו את Inokim KIX החדש</h6>
          <h1 class="mb-1">קלילות ועוצמה נפגשים</h1>
          <p class="mb-4">
            <%= product.overviewSubtitle %>
          </p>

          <div class="d-flex justify-content-start gap-3 col-12 col-md-9">
            <a href="/products/inokim-kix" class="btn btn-danger w-100">הזמן עכשיו</a>
            <a href="#learn" class="btn btn-light w-100">גלה עוד</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="overlay" style="
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: rgba(255,255,255,0.1);
  "></div>
</section>

  <section class="design-section py-5 text-light text-center">
    <div class="">
      <div class="content-header">
        <% 
          const designBlock = product.contentBlocks.find(b => b.title === 'עיצוב פורץ דרך');
        %>
        <div>
          <h2 class="mb-3"><%= designBlock ? designBlock.title : 'עיצוב שנע יחד איתך' %></h2>
          <p class="mb-5">
            <%= designBlock ? designBlock.content : 'שילוב מושלם בין אלגנטיות לפונקציונליות. חדשנות בלי מאמץ.' %>
          </p>
        </div>
      </div>

<div class="swiper mySwiper px-5">
        <div class="swiper-wrapper">

          <% 
          let slideIndex = 1;
          const contentBlocksToLoop = product.contentBlocks.filter(b => b.type === 'imageWithText');
          
       
              contentBlocksToLoop.forEach(block => { 
          %>
              <div class="swiper-slide">
                <div class="card bg-dark border-0 rounded-4 overflow-hidden mb-2">
                  <img src="<%= s3path %><%= block.image || '/optimized/default-slide.png' %>" class="card-img" alt="<%= block.title %>">
                  <div class="card-img-overlay d-flex flex-column justify-content-end text-end p-3">
                    <div class="d-flex justify-content-between align-items-center">
                    </div>
                  </div>
                </div>
                <div class="d-flex-col text-end">
                    <h3 class="mb-0"><%= block.title %></h3>
                    <p>
                        <%= block.content %>
                    </div>
              </div>
              
          <% 
              slideIndex++; 
              }); 

              
         
          %>
        </div>
      </div>
    </div>
  </section>


  <section class="kix-specs-section py-5 bg-white text-end" id="learn">
  <div class="container">
    <div class="row align-items-center">

            <div class="col-lg-6 col-md-12 position-relative order-2 order-md-1">
            <div class="specs-image-wrapper position-relative d-flex justify-content-center justify-content-lg-end">
            <video autoplay muted loop playsinline class="specs-video-bg">
                <source src="/videos/vid2.mp4" type="video/mp4">
                הדפדפן שלך לא תומך בהצגת וידאו.
              </video>

           <img 
