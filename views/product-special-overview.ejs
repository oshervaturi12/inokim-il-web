<%- include("./partials/announcement.ejs", { 
    text: announcement?.text || null, 
    buttonLink: null, 
    buttonText: null ,
    isSale: false
  }) %>

<%- include("./partials/navbar.ejs", { customClass: customClass }) %>



<main id="special-template">
    <div class="overview" style="--background: url('<%= `${s3path}${overviewImage}`%>')">
        <div class="container">
            <div class="row align-items-center">
                <!-- Left Section: Product Details -->
                <div class="col-12 col-md-5 order-2 order-md-1">
                    <div class="content-wrapper">
                        <header>
                          <%- optimizeImage(`/optimized${logoSvg}`, "Cyborg Logo", 'lazyload') %>
                          <small>מותאם לכל דגמי אוקס מ-2018*</small>

                            <h1>בטיחות, שליטה <span>וחיבור חכם לאוקס שלך</span></h1>
                            <p class="subheading">מסך חכם תומך Apple CarPlay</p>
                            <p class="subheading mb-3">לחיבור ישיר ופשוט לאוקס</p>
                        </header>
                        <div class="price-box">
                            <span class="price"> <%= formatter.format(price)  %> </span>
                            <span class="installments">או <%= formatter.format(Math.ceil(price / 36)) %> × 36 לחודש</span>

                        </div>
                        <div class="d-flex gap-3 w-100">

                        <a href="/products/<%=slug %>" class="btn btn-danger w-100">לרכישה</a>
                        <button type="button" class="btn btn-light w-100" data-bs-toggle="modal" data-bs-target="#cyborgInstruction">
                          הוראות התקנה
                        </button>
                        </div>
                      
                    </div>
                </div>

                <!-- Right Section: Product Image -->
                <div class="col-12 col-md-7 order-1 order-md-2 text-center mt-3 mt-md-0">

                    <img src="<%=s3path  %>/optimized/cyborg-header.png" alt="Cyborg Display" class="product-image">
                </div>
            </div>

            <!-- Footer Text -->
            <div class="text-center mt-5 lastEl">
                <span class="apple-carplay-text">היחיד בארץ שתומך Apple CarPlay + Android</span>
                <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="51.41" height="56.512" viewBox="0 0 51.41 56.512">
                    <defs>
                    <clipPath id="clip-path">
                        <rect id="Rectangle_6" data-name="Rectangle 6" width="51.41" height="56.512" transform="translate(0 0)" fill="none"/>
                    </clipPath>
                    </defs>
                    <g id="Group_11" data-name="Group 11" transform="translate(0 0.002)">
                    <g id="Group_10" data-name="Group 10" transform="translate(0 -0.002)" clip-path="url(#clip-path)">
                        <path id="Path_231" data-name="Path 231" d="M28.256,56.511A28.256,28.256,0,1,1,51.132,11.666a1.579,1.579,0,0,1-2.554,1.855,25.1,25.1,0,1,0-.023,29.5,1.578,1.578,0,0,1,2.55,1.859A28.364,28.364,0,0,1,28.256,56.511ZM23.113,16.16a1.451,1.451,0,0,0-.749-.337,1.049,1.049,0,0,0-1.049,1.049V39.259a1.049,1.049,0,0,0,1.6.889c.2-.124,19.16-10.938,19.344-11.1a1.049,1.049,0,0,0,.089-1.5c-.192-.21-18.92-11.159-19.237-11.392" transform="translate(0 0.001)" fill="#fff"/>
                    </g>
                    </g>
                </svg>
            </div>

    

        </div>
    </div>

    <div class="section-info-special mb-3 mb-md-5">
        <div class="row">


            <div class="col-12 col-md-8">
                <div class="box" id="videoBox">
                  <video autoplay muted loop playsinline>
                    <source src="<%= overviewVideo  %>" type="video/mp4">
                    הדפדפן שלך לא תומך בנגן וידאו.
                  </video>
                </div>
              </div>

            <div class="col-12 col-md-4">
                <div class="text px-3 py-2 py-md-5">
             
                    <h2>משאירים את        <span class="d-md-block">הסלולרי בכיס</span></h2>
                    <p class="mb-3">
                        <p>
                            ה-INOKIM CYBORG הופך את דגם ה-OX לקורקינט החכם בעולם עם מסך חכם מתקדם שמביא איתו חוויית רכיבה ייחודית.  
                            עם <strong>CarPlay מובנה</strong>, <strong>דיבורית</strong>, <strong>ניווט מתקדם באמצעות Waze</strong>,  
                            שליטה מלאה על ההגדרות וניטור ביצועים בזמן אמת – כל מה שצריך בקורקינט חכם, עכשיו זמין בלחיצת כפתור.
                        </p>
                        <p> תיהנו מחוויית רכיבה מחוברת, בטוחה ומתקדמת יותר מאי פעם!</p>
                       </p>
                       
                       <a href="/products/<%= slug  %>" class="btn btn-danger">לרכישה</a>
                </div>
            </div>
        
        </div>

    </div>


    <div class="special-specs container mb-3 mb-md-5 p-3">
      <div class="d-flex flex-wrap align-items-center justify-content-center gap-4">
        <% const featuresCategory = product.specs.find(c => c.category === "תכונות נוספות" || c.category === "תכונות מרכזיות"); %>
    
        <% if (featuresCategory) { %>
          <div class="spec-item">
            <%= featuresCategory.category %>
          </div>
    
          <% featuresCategory.items.forEach(item => { %>
            <div class="spec-item text-center">
              <% if (item.icon) { %>
               <%- item.icon %>
              <% } %>
              <div><%= item.label %></div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="spec-item">
            לא קיימות תכונות נוספות להצגה.
          </div>
        <% } %>
      </div>
    </div>
    


    <div class="tech-specs mb-3 mb-md-5">
      <div class="row no-gutters">
      
        <div class="col-12 col-md-4 order-2 order-md-1">
          <div class="spec-text p-3 p-md-5">
            <% 
              const specCategory = product.specs.find(c => c.category === "מפרט טכני"); 
            %>
    
            <% if (specCategory) { %>
              <h3 class="border-bottom py-3"><%= specCategory.category %></h3>
    
              <% specCategory.items.forEach(item => { %>
                <div class="d-flex justify-content-between py-3 border-bottom">
                  <span><%= item.label %></span>
                  <strong><%= item.value %></strong>
                </div>
              <% }) %>
            <% } %>
    
            <a href="/products/<%= slug %>" class="btn btn-danger mt-3">לרכישה</a>
          </div>
        </div>
    
        <div class="col-12 col-md-8 p-0 p-mobile order-1 order-md-2">
          <div class="tech-specs-img" style="--background: url('<%=s3path  %>/optimized/bg-2.png')">
            <img src="<%=s3path  %>/optimized/01-2.png" alt="">
          </div>
        </div>
      </div>
    </div>
    
    


