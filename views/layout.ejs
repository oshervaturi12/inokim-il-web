<!-- 3201406643204985 -->
  <!-- Meta Pixel Code -->
    <script>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '<%= storeSettings.analytics.facebookPixelId %>');
      fbq('track', 'PageView');


      <% 
        let cartValue = 0;
        let numItems = 0;
        let contentIds = [];
        if (typeof cart !== 'undefined' && cart && cart.items && cart.items.length > 0) {
          cartValue = cart.totalPrice || 0;
          numItems = cart.items.reduce((sum, item) => sum + item.quantity, 0);
          contentIds = cart.items.map(item => item.sku || item.prdId || item._id);
        }
      %>

      if (window.location.pathname.startsWith('/checkout')) {
        fbq('track', 'InitiateCheckout', {
          value: <%= cartValue %>,                 
          currency: 'ILS',                     
          num_items: <%= numItems %>,          
          content_ids: <%- JSON.stringify(contentIds) %>, 
          content_type: 'product'           
        });
      }


      </script>
      <noscript><img height="1" width="1" style="display:none"
      src="https://www.facebook.com/tr?id=<%= storeSettings.analytics.facebookPixelId %>&ev=PageView&noscript=1"
      /></noscript>
  <!-- End Meta Pixel Code -->

  <% }  %>

