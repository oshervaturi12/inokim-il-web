<!DOCTYPE html>
<html lang="he" dir="rtl" data-bs-theme="light">

<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Dynamic SEO Tags -->
  <title><%= typeof seo !== 'undefined' && seo.pageTitle ? seo.pageTitle : (typeof title !== 'undefined' ? title : 'Inokim') %></title>
  <meta name="description" content="<%= typeof seo !== 'undefined' && seo.metaDescription ? seo.metaDescription : (typeof description !== 'undefined' ? description : 'ברוכים הבאים לאינוקים - הקורקינטים החשמליים הטובים ביותר בישראל!') %>">

   <meta name="robots" content="<%= typeof seo !== 'undefined' && seo.noIndex ? 'noindex, nofollow' : 'index, follow' %>">

  <link rel="canonical" href="<%= typeof seo !== 'undefined' && seo.canonicalUrl ? seo.canonicalUrl : '' %>">
  
  <!-- Open Graph Meta Tags (For Social Sharing) -->
  <meta property="og:title" content="<%= typeof seo !== 'undefined' && seo.ogTitle ? seo.ogTitle : (typeof title !== 'undefined' ? title : 'Inokim') %>">
  <meta property="og:description" content="<%= typeof seo !== 'undefined' && seo.metaDescription ? seo.metaDescription : (typeof description !== 'undefined' ? description : 'קורקינטים חשמליים הטובים ביותר בישראל') %>">
  <meta property="og:image" content="<%= typeof seo !== 'undefined' && seo.ogImage ? seo.ogImage : '/img/default-og-image.png' %>">
  
  <!-- Twitter Card Meta Tags -->
  <meta name="twitter:title" content="<%= typeof seo !== 'undefined' && seo.twitterTitle ? seo.twitterTitle : (typeof title !== 'undefined' ? title : 'Inokim') %>">
  <meta name="twitter:description" content="<%= typeof seo !== 'undefined' && seo.twitterDescription ? seo.twitterDescription : (typeof description !== 'undefined' ? description : 'קורקינטים חשמליים מעוצבים ובטיחותיים') %>">
  <meta name="twitter:image" content="<%= typeof seo !== 'undefined' && seo.twitterImage ? seo.twitterImage : '/img/default-twitter-image.png' %>">
  

  <!-- Theme Color -->
  <meta name="theme-color" content="<%= typeof themeColor !== 'undefined'? themeColor: "#ffff" %>">

  <!-- Favicon -->
  <link rel="shortcut icon" href="https://d3kxrpm9y5cv3a.cloudfront.net/optimized/favicon_192.png" type="image/x-icon" sizes="16x16" />

  <!-- Font -->
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Hebrew:wght@100..900&display=swap" rel="stylesheet">

  <!-- App CSS -->
  <link rel="stylesheet" href="<%= manifest['css.css'] %>">

  <!-- PWA Manifest -->
  <link rel="manifest" href="/manifest.json">

