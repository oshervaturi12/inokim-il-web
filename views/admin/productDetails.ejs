<%- include("./partials/header-admin.ejs") %>

<main class="p-3">
    <div>
        <form id="editPrd">
            <div class="row">
                <!-- Product Info Section -->
                <main class="col-12 col-md-8">


                    <div class="row">
                        
                        <div class="box border mb-3">
                        <h5>פרטי מוצר</h5>
                        <!-- Product Name -->
                        <div class="col-12 col-md-12 mb-3">
                            <label for="productName" class="form-label">שם המוצר</label>
                            <input type="text" id="productName" name="name" class="form-control" value="<%= product.name %>">
                        </div>

                        <!-- Product Description -->
                        <div class="col-12 col-md-12 mb-3">
                            <label for="productDescription" class="form-label">תיאור המוצר</label>
                            <textarea class="form-control" name="description" id="content" rows="5"><%= product.description %></textarea>
                        </div>

                        <div class="col-12 col-md-12 mb-3">
                            <label for="productDescription" class="form-label">תמונות</label>
                            <div class="border rounded d-flex flex-wrap p-3">
                                    <% if(product.gallery && product.gallery.length > 0) { %>

                                        <% product.gallery.forEach(img =>{ %>

                                            <div class="img-thumbnail w-50">
                                                <img src="<%= img  %>" alt="">
                                            </div>


                                       <% }) %>

                                   <% } %>
                            </div>
                        </div>
                   
                        <div class="col-12 col-md-12 mb-3">
                            <label for="productDescription" class="form-label">קטגוריה</label>
                            <input type="text" id="productName" name="name" class="form-control" value="">

                        </div>

                    </div>

                    <div class="box border mb-3">
                        <!-- Price -->
                         <h5>מחיר</h5>
                         <div class="row">
                            <div class="col-12 col-md-4 mb-3">
                                <label for="productPrice" class="form-label">מחיר</label>
                                <input type="number" id="productPrice" name="price" class="form-control" value="<%= product.price %>">
                            </div>
    
                            <div class="col-12 col-md-4 mb-3">
                                <label for="productPrice" class="form-label">מחיר מבצע</label>
                                <input type="number" id="productPrice" name="price" class="form-control" value="<%= product.price %>">
                            </div>

                            <div class="col-12 col-md-4 mb-3">
                                <label for="productPrice" class="form-label">מחיר עלות</label>
                                <input type="number" id="productPrice" name="price" class="form-control" value="<%= product.price %>">
                            </div>
    
                              <!-- Internal SKU -->
                              <div class="col-12 col-md-6 mb-3">
                                <label for="productBarcode" class="form-label">מק״ט</label>
                                <input type="text" id="productBarcode" name="barcode" class="form-control" value="<%= product.barcode || '' %>">
                            </div>


                        <!-- Order Priority -->
                        <div class="col-12 col-md-6 mb-3">
                            <label for="order" class="form-label">סדר תצוגה</label>
                            <input type="number" id="order" name="order" class="form-control" value="<%= product.order || '' %>">
                        </div>
                    </div>
                    </div>
                  
                    <div class="box border mb-3">
                        <h5>מלאי</h5>
                        <div class="row">
                            <div class="col-12 col-md-4 mb-3">
                                <label for="order" class="form-label">כמות</label>
                                <input type="number" id="order" name="order" class="form-control" value="<%= product.order || '' %>">
                            </div>
                        </div>
                     </div>
                    
                     <div class="box border mb-3">
                        <h5>SEO</h5>
                        <div class="row">
                            <div class="col-12 col-md-12 mb-3">
                                <label for="order" class="form-label">כותרת עמוד</label>
                                <input type="number" id="order" name="order" class="form-control" value="<%= product.order || '' %>">
                            </div>

                            <div class="col-12 col-md-12 mb-3">
                                <label for="order" class="form-label">תיאור מטא</label>
                                <textarea class="form-control" name="description" id="content" rows="5"></textarea>
                            </div>
                            <div class="col-12 col-md-12 mb-3">
                                <label for="order" class="form-label">קישור</label>
                                <input type="number" id="order" name="order" class="form-control" value="<%= product.order || '' %>">
                            </div>
                        </div>
                     </div>

                </main>

                <!-- Sidebar: Product Status & Insights -->
                <aside class="col-12 col-md-4">
                    <!-- Status Selector -->
         
                        <div class="box border mb-3">
                            <h5>סטטוס</h5>
                            <div class="mt-3">
                                <select name="status" class="form-select">
                                    <option value="draft" <%= product.status === 'draft' ? 'selected' : '' %>>טיוטה</option>
                                    <option value="active" <%= product.status === 'active' ? 'selected' : '' %>>פעיל</option>
                                    <option value="archived" <%= product.status === 'archived' ? 'selected' : '' %>>ארכיון</option>
                                </select>
                            </div>
                        </div>
                   

                    <!-- Product Metadata -->
          
                        <div class="box border mb-3">
                            <h5>נתוני מוצר</h5>
                            <div><strong class="ms-3">תאריך יצירה:</strong> <%= product.createdAt ? product.createdAt.toLocaleDateString('he-IL') : 'N/A' %></div>
                            <div><strong class="ms-3">תאריך עדכון:</strong> <%= product.updatedAt ? product.updatedAt.toLocaleDateString('he-IL') : 'N/A' %></div>
                        </div>

                

                    <!-- Sales Insights -->
                        <div class="box border">

                            <h5>תובנות</h5>
                            <p>מוצר זה נמכר: <strong> <%= product.totalSold || 0 %> </strong> פעמים בסך כולל של : <strong> ₪<%= (product.totalSold * product.price) || 0 %> </strong></p>
                        </div>
           
                </aside>
            </div>

            <!-- Hidden Product ID -->
            <input type="hidden" name="prdId" value="<%= product._id %>">

            <!-- Save Bar -->
            <div class="save-bar">
                <div class="save-bar__status">
                    <span class="status-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14h2v2h-2zm0-8h2v6h-2z" fill="#fff"></path>
                        </svg>
                    </span>
                    <span class="status-text"><%= product.name %> לא שמור</span>
                </div>
                <div class="save-bar__actions">
                    <button type="button" class="btn btn-secondary">בטל שינויים</button>
                    <button type="submit" class="btn btn-light">שמור שינויים</button>
                </div>
            </div>
        </form>
    </div>
</main>

<%- include("./partials/admin-footer.ejs") %>
