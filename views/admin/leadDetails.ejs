<%- include("./partials/header-admin.ejs") %>

<main id="app-in-con">

                

    <div class="py-3 px-3 py-md-4">
    
        <form action="#" method="post" id="addLead">
    
            <h1 class="dash-title big mb-4">
                                פרטי ליד <span class="badge bg-danger ms-1">1234</span>
                
            </h1>
    
    
            <div class="row flex-column-reverse flex-md-row">
    
                <div class="col-12 col-md-8">
    
                    <div class="box border mb-4">
    
                        <div class="row">
                            <div class="col-12 col-md-6 mb-3">
                                <label class="form-label">שם מלא</label>
                                <input type="text" name="first_name" class="form-control" value="<%= lead.fullName %>" required="">
                            </div>
    
                            <div class="col-12 col-md-6 mb-3">
                                <label class="form-label">טלפון</label>
                                <input type="text" name="phone" class="form-control" value="<%= lead.phone %>" required="">
                            </div>
    
                        </div>
    
                        <div class="mb-3">
                            <label class="form-label">אימייל</label>
                            <input type="email" name="email" class="form-control" value="<%= lead.email %>" required="">
                        </div>
    
    
                        <div class="mb-3">
                            <label class="form-label">נושא</label>
                            <input type="text" name="topic" class="form-control" value="<%= lead.type %>" required="">
                        </div>
    
                        <div class="mb-3">
                            <label class="form-label">הודעה</label>
                            <textarea name="body" class="form-control" rows="6" required="">
                                <%= lead.message %>
                                </textarea>
                        </div>
    
    
                        
                        
    
                        
                        
                        
                        
                        
    
                        
                            <input type="hidden" name="id" value="292">
    
                                                        <button type="submit" class="btn btn-danger">עדכון ליד</button>
                            
                                                        <button type="button" class="btn btn-light ms-1 " id="del" data-id="292">מחיקת ליד</button>
                            
                        
                    </div>
    
    
                </div>
    
    
                
                    <div class="col-12 col-md-4">
    
                        <div class="box border mb-4">
    
                            <div class="mb-3">
                                <label class="form-label">תאריך יצירה</label>
                                <input type="date" class="form-control" value="2025-03-13" readonly="">
                            </div>
    
                            
                            <div>
                                <label class="form-label">סטטוס</label>
                                <select name="status" class="form-control" required="">
                                    <option value="1">ממתין לטיפול</option>
                                    <option value="2">סגור</option>
                                    <option value="3">אושר</option>
                                </select>
                            </div>
    
                                                        <div class="mt-3">
                                    <label class="form-label">הערות מנהל</label>
                                    <textarea class="form-control" name="admin_notes" rows="4"></textarea>
                                </div>
                                                </div>
    
                    </div>
                        </div>
        </form>
    
        
        <form action="#" method="post" id="leadTimeline">
    
            <h2 class="dash-title mb-3">ציר זמן</h2>
    
            <div id="timeline">
    
                            <div class="form mt-2">
                    <input type="hidden" name="leadID" value="292">
                    <input type="text" name="title" class="form-control mb-2" placeholder="כותרת">
                    <textarea name="content" class="form-control" rows="5" placeholder="תוכן" required=""></textarea>
                    <button type="submit" class="btn btn-danger mt-2">עדכן</button>
                </div>
    
    
            </div>
    
        </form>
    
        
    </div>
    
        </main>

<%- include("./partials/admin-footer.ejs") %>