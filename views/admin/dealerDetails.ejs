<%- include("./partials/header-admin.ejs") %>


<main id="app-in-con">
    <div class="py-3 px-3 py-md-4">
        <form action="/admin/dealers/edit/<%= dealer._id %>" method="POST" id="editDealerForm">
            <h1 class="dash-title big mb-4">
                עריכת מפיץ: <span class="badge bg-danger ms-1"><%= dealer.name %></span>
            </h1>

            <div class="row flex-column-reverse flex-md-row">
                <!-- Left Section -->
                <div class="col-12 col-md-8">
                    <div class="box border mb-4">
                        <div class="row">
                            <div class="col-12 col-md-6 mb-3">
                                <label class="form-label">שם</label>
                                <input type="text" name="name" class="form-control" value="<%= dealer.name %>" required>
                            </div>

                            <div class="col-12 col-md-6 mb-3">
                                <label class="form-label">סוג</label>
                                <select name="type" class="form-control" required>
                                    <option value="מפיץ רשמי" <%= dealer.type === "מפיץ רשמי" ? "selected" : "" %>>מפיץ רשמי</option>
                                    <option value="חנות אינוקים" <%= dealer.type === "חנות אינוקים" ? "selected" : "" %>>חנות אינוקים</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">כתובת</label>
                            <input type="text" name="address" class="form-control" value="<%= dealer.address %>" required>
                        </div>

                        <div class="row">
                            <div class="col-12 col-md-6 mb-3">
                                <label class="form-label">קו רוחב (Latitude)</label>
                                <input type="text" name="coordinates[lat]" class="form-control" value="<%= dealer.coordinates.lat %>" required>
                            </div>
                            <div class="col-12 col-md-6 mb-3">
                                <label class="form-label">קו אורך (Longitude)</label>
                                <input type="text" name="coordinates[lng]" class="form-control" value="<%= dealer.coordinates.lng %>" required>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12 col-md-6 mb-3">
                                <label class="form-label">טלפון</label>
                                <input type="text" name="contact[phone]" class="form-control" value="<%= dealer.contact.phone %>" required>
                            </div>

                            <div class="col-12 col-md-6 mb-3">
                                <label class="form-label">אימייל</label>
                                <input type="email" name="contact[email]" class="form-control" value="<%= dealer.contact.email || '' %>">
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">קישור</label>
                            <input type="url" name="link" class="form-control" value="<%= dealer.link %>" required>
                        </div>

                        <button type="submit" class="btn btn-danger">עדכון מפיץ</button>
                        <button type="button" class="btn btn-light ms-1" id="deleteDealer" data-id="<%= dealer._id %>">מחיקת מפיץ</button>
                    </div>
                </div>

                <!-- Right Section -->
                <div class="col-12 col-md-4">
                    <div class="box border mb-4">
                        <div class="mb-3">
                            <label class="form-label">תאריך יצירה</label>
                            <input type="text" class="form-control" value="<%= new Date(dealer.createdAt).toISOString().split('T')[0] %>" readonly>
                        </div>

                        <div>
                            <label class="form-label">סטטוס</label>
                            <select name="status" class="form-control" required>
                                <option value="1">פעיל</option>
                                <option value="2">לא פעיל</option>
                            </select>
                        </div>

                  
                    </div>
                </div>
            </div>
        </form>


    </div>
</main>




<%- include("./partials/admin-footer.ejs") %>