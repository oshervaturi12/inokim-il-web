                עמוד תשלום מאובטח</h1>
    
            <div class="row g-md-5 mt-auto align-items-start justify-content-center">
    
                <div id="orderPaymentInfo" class="col-12 col-md-8">
                     <iframe src="<%=fullLink %>" width="100%" height="100%" id="directIframe"></iframe>
                </div>
    
    
                
                    <aside class="col-12 col-md-4 mb-3 mb-md-0" id="checkout-side">
    
                        <button class="show-check-btn d-flex d-md-none" type="button" data-bs-toggle="collapse" data-bs-target="#colCheckout" aria-expanded="false" aria-controls="colCheckout">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 50 50"><path d="M38.83 46H11.24a6.46 6.46 0 0 1-6.5-6.42 4.71 4.71 0 0 1 0-.75l2.16-19a3.23 3.23 0 0 1 3.23-2.88h29.76a3.22 3.22 0 0 1 3.23 2.88l2.1 19A6.45 6.45 0 0 1 39.51 46a5.07 5.07 0 0 1-.68 0ZM12.11 16.92a12.93 12.93 0 0 1 25.85 0" style="fill:none;stroke:#353535;stroke-linecap:round;stroke-linejoin:round;stroke-width:3px"></path><line x1="16.96" x2="33.11" y1="26.62" y2="26.62" style="fill:none;stroke:#353535;stroke-linecap:round;stroke-linejoin:round;stroke-width:2px"></line></svg>
                            הצג פרטי עגלה
                        </button>
    
                        <div class="collapse d-md-block" id="colCheckout">
    
                            <!-- <div id="checkout-mobile-title" class="nice-title d-none d-md-flex">עמוד תשלום פרטי העגלה</div> -->
    
                            <div id="cart-items">
                                <div class="cart-view">
    
        <div class="cart-view-items">

            <% if(order.items && order.items.length > 0) { %>
                <% order.items.forEach(item =>{ %>

                <div class="item">
    
                    <picture>
                        <source srcset="<%= item.img  %>" type="image/webp">
                        <img alt="<%= item.name  %>" src="<%= item.img  %>">
                    </picture>
    
                    <div class="text">
                        <a class="title">  <%= item.prdName %> </a>
                        <ul>
    
                            
                                                <li>מחיר:  <%=  formatter.format(item.price) %>    </li>
                            
                                
                            
    
                            
    
                                 <li>כמות: <%=  formatter.format(item.quantity) %> </li>

                                 <% if(item.sku && item.sku !== "") { %>
                                    <li>מקט: <%= item.sku  %> </li>
                                <% } %>
                            
    
                        </ul>
                    </div>
    
                 </div>
                 <% }) %>
           <% } %>
            
        
    

    
                </div>

    
    </div>                        </div>
    
                            <div id="cart-sum">
    
                                <ul>
                                    <li>
                                        <span>מוצרים</span>
                                        <span> <%= formatter.format(order.totalPrice) %> </span>
                                    </li>
    
                                    
                                    
                                    <li>
                                        <span>משלוח</span>
                                        <span>

                                            <% if(order.shippingMethod === "home_delivery") { %>
                                                <span id="del-price">
                                                    <%= order.shippingCost  %>
                                                </span>
                                           <% } else { %>
                                            <span id="del-price">
                                                איסוף עצמי - ללא עלות
                                            </span>
                                         <%  } %>
                                  
                                </span>
                                    </li>
                                    <li class="total">
                                        <span>סך הכל</span>
                                        <span>
                                    <span id="total-price"> <%= formatter.format(order.totalPrice + order.shippingCost)  %>  </span>
                                </span>
                                    </li>
                                </ul>
    
                            </div>
    
                        </div>
    
    
                    </aside>
    
                
    
            </div>
    
        </div>
    </div>

    

    
    </main>

