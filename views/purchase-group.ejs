

<%- include("./partials/navbar.ejs", { customClass: customClass }) %>


  <style>

    .main-page{
        background-color: #f8f9fa;
    }

    .main-page .home-prd{
        background-color: #ffff;
    }

        .main-page p{
            padding: 0;
            margin: 0;
            letter-spacing: 0;
            font-size: 18px;
        }

    .hero-purchase {
      background: linear-gradient(
        135deg,
        #E6B800,   
        #FFCD00,  
        #FFD84D  
      );
      color: #000000;
      padding: 80px 20px;
      /* height: 60svh; */
    }

       .hero-purchase p{
        font-weight: 500;
       }

       .hero-purchase h1{
        color: #004E78;
       }

     .hero-purchase img{
        width: 13em;
     }

    .hero-purchase h1 {
      font-weight: 800;
    }

    .badge-custom {
      background-color: rgba(255,255,255,0.15) !important;
      border: 1px solid rgba(255,255,255,0.3) !important;
      color: #000000;
    }

    .section {
      padding: 60px 0;
    }

    .card {
      border-radius: 16px;
    }

    .form-control {
      border-radius: 10px;
    }

    .btn-primary {
      background-color: #198754;
      border-color: #198754;
      border-radius: 12px;
      padding: 12px 24px;
      font-weight: 600;
    }

    .btn-primary:hover {
      background-color: #157347;
      border-color: #157347;
    }

    .card svg{
        width: 1.5em;
        height: 1.5em;
    }

    .btn-register {
  background: linear-gradient(
    135deg,
    #1F7A4D,   /* deep green */
    #2FA36B    /* fresh green */
  );
  color: #ffffff;
  border: none;
  border-radius: 8px !important;
  padding: 14px 24px;
  font-size: 17px;
  font-weight: 600;
  letter-spacing: 0.2px;
  box-shadow: 0 6px 16px rgba(31, 122, 77, 0.25);
  transition: all 0.25s ease;
}

.btn-register:hover {
  background: linear-gradient(
    135deg,
    #1B6B44,
    #27945F
  );
  box-shadow: 0 8px 22px rgba(31, 122, 77, 0.35);
  transform: translateY(-1px);
}

.btn-register:active {
  transform: translateY(0);
  box-shadow: 0 4px 12px rgba(31, 122, 77, 0.25);
}

.btn-register:focus-visible {
  outline: none;
  box-shadow:
    0 0 0 3px rgba(47, 163, 107, 0.35),
    0 6px 16px rgba(31, 122, 77, 0.25);
}

.price-list .list-group-item {
  font-size: 17px;
}

.price-tag {
  font-weight: 600;
  color: #198754;
  font-size: 18px;
    line-height: 1.2;
}

.old-price {
  font-size: 16px;
  color: #6c757d;
  text-decoration: line-through;
}

.price-modal-trigger {
  color: #198754;
  font-weight: 500;
  text-decoration: underline;
  text-underline-offset: 4px;
}

.price-modal-trigger:hover {
  color: #157347;
  text-decoration-thickness: 2px;
}


  @media (max-width: 768px) {

      .hero-purchase .btn{
        width: 100% !important;
      }
  }


  </style>

<main class="main-page">


  <!-- HERO -->
  <section class="hero-purchase text-center">
    <div class="container">
      <span class="badge badge-custom mb-3 d-inline-block">
        קבוצת רכישה ייעודית לסטודנטים בירושלים
      </span>

      <div class="d-flex justify-content-center align-items-center">
          <img class="img-fluid" src="/optimized/k.png" alt="">
      </div>

      <h1 class="display-5 mt-3">
        קורקינט חשמלי 
        <span>
            במחיר סטודנטיאלי
        </span>
      </h1>

      <p>
        התעוררות בירושלים ואינוקים מזמינות אתכם להצטרף לקבוצת רכישה לקורקינטים 
        <strong>חכם, זול, ירוק ומושלם לחיים בעיר</strong>.
      </p>

      <a href="#signup" class="btn btn-dark mt-4">
         כל הפרטים כאן
      </a>
    </div>
  </section>




  <!-- ABOUT -->
  <section class="section">
    <div class="container">
