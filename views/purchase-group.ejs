    <!-- WHY INOKIM -->
<section class="section bg-light">
  <div class="container">
    <div class="row justify-content-center text-center mb-4">
      <div class="col-lg-8">
        <h2 class="mb-3">למה אינוקים?</h2>
        <p>
          כשבוחרים קורקינט  לא בוחרים רק כלי תחבורה,  
          בוחרים שותף לדרך.
        </p>
      </div>
    </div>

  <div class="row justify-content-center align-items-center">
  <div class="col-lg-9">
    <p>
      <strong>Inokim</strong> היא אחת החברות המובילות בישראל בתחום הקורקינטים החשמליים,
      עם ניסיון של שנים בפיתוח, ייצור וליווי אלפי רוכבים ביום יום העירוני.
    </p>

    <p>
      הקורקינטים של אינוקים מתוכננים במיוחד לתנאי העיר
      אמינות גבוהה, נוחות רכיבה, בטיחות מוקפדת ושירות זמין גם אחרי הרכישה.
    </p>


    <p>
      הקורקינטים שנבחרו לקבוצת הרכישה מותאמים לתוואי ההררי של ירושלים,
      ומספקים ביצועים שמאפשרים התמודדות קלה עם עליות מאתגרות 
      כן, גם את רחוב בצלאל.
    </p>

    <p>
      במסגרת שיתוף הפעולה עם <strong>התעוררות ירושלים</strong>,
      נבחרו דגמים שעומדים בסטנדרטים הגבוהים של אינוקים
      ומוצעים כאן במחיר נגיש במיוחד לסטודנטים.
    </p>

    <p class="mb-0">
      זו לא “עסקה חד־פעמית”,  
      אלא פתרון תחבורה חכם, אחראי ולטווח ארוך.
    </p>
  </div>
</div>

  </div>
</section>

    <section class="home-prd">
      <div class="container">
        <div class="our-team">
          <div class="text"> <%= home.productHighlightsTitle%> </div>

          <div class="d-none d-md-block">
            <%- optimizeImage(`${home.productHighlightsImage}`, 'קולקציית אינוקים', 'img-fluid') %>
          </div>


          <div class="d-block d-md-none">
             <%- optimizeImage(`/optimized/test.png`, 'קולקציית אינוקים', 'img-fluid') %>
          </div>
        


        </div>
      </div>
        <div class="items d-none d-md-flex py-3">
          <% home.productHighlights.forEach(product => { %>
            <div class="item">
              <div class="icon"><%- product.iconSvg %></div>
              <div class="line">
                <span>
                  <span data-bs-toggle="tooltip" data-bs-title="עד <%= product.range  %> ק״מ ט.ל.ח">*טווח</span>
                <span><%= product.range %></span>
              </span>
                <span class="divider-line">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 23.85 53.77"><path stroke="#000" stroke-width="2" d="m22.92.38-22 53" data-name="Line 5"></path></svg>
                </span>
                <span><span>מהירות</span><span><%= product.speed %></span></span>
              </div>
         
            </div>
          <% }) %>
        </div>
     
     
    </section>
  <!-- TARGET -->
  <section class="section">
    <div class="container">
      <div class="row justify-content-center text-center">
        <div class="col-lg-6">
          <h2 class="mb-2">למי זה מיועד?</h2>
          <p>
             סטודנטים וסטודנטיות שלומדים בירושלים  
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SIGNUP -->
  <section id="signup" class="section bg-white">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-6">
          <div class="card shadow p-3 p-md-5">
            <h2 class="text-center mb-4">
              הרשמה לקבוצת הרכישה
            </h2>

            <form method="post" action="/signup" class="dynamic-form">
              <div class="mb-3">
                <label class="form-label">שם מלא</label>
                <input
                  type="text"
                  name="fullName"
                  class="form-control"
                  required
                />
              </div>

              <div class="mb-3">
                <label class="form-label">טלפון</label>
                <input
                  type="tel"
                  name="phone"
                  class="form-control"
                  required
                />
              </div>

              <div class="mb-4">
                <label class="form-label">אימייל</label>
                <input
                  type="email"
                  name="email"
                  class="form-control"
                  required
                />
              </div>

              <input type="hidden" name="type" value="purchase-group" id="">

              <div class="d-grid">
              <button type="submit" class="btn btn-register">
                להצטרפות לקבוצת הרכישה
              </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

