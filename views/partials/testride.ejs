<div class="section-testride">
    <h2><%= title %></h2>
    <p><%= subtitle %></p>
  
    <form id="prd-test-ride-form" class="dynamic-form">
      <div class="row g-3">
        <div class="col-12 col-md-4">
          <input type="text" name="fullName" class="form-control" placeholder="שם מלא" required>
        </div>
        <% if(type === "newsletter") { %>
          <div class="col-12 col-md-4">
            <input type="email" name="email" class="form-control" placeholder="אימייל" required>
          </div>
       <% } else { %>
        <div class="col-12 col-md-4">
          <input type="text" name="address" class="form-control" placeholder="עיר מגורים" required>
        </div>
      <% } %>
     
      <div class="col-12 col-md-4">
        <input type="tel" name="phone" class="form-control" placeholder="טלפון" required>
      </div>
       
      </div>
      <% if(typeof product !== 'undefined' && product) { %>
        <input type="hidden" name="model" value="<%= product %>">
     <% } %>
      <input type="hidden" name="type" value="<%= type %>">
      <button type="submit" class="btn">שליחה</button>
    </form>
  </div>
  