<div class="modal fade" id="staticBackdrop" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h1 class="modal-title fs-5" id="staticBackdropLabel">השוואת <%= product.name  %></h1>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">

        <div class="img d-flex align-items-center justify-content-center mb-3">
          <img src="<%= `${s3path}${product.variants[0].gallery[0].replace('/img', '/optimized') }` %>" class="img-fluid w-50" alt="קוריקנט אינוקים">

        </div>

        <!-- Variant Prices -->
        <div class="d-flex justify-content-around align-items-center mb-5">
          <% if(product.variants && product.variants.length > 0) { %>
            <% product.variants.forEach(el =>{ %>
              <div class="d-flex flex-column align-items-center justify-content-center">
                <h5><%= el.subModel  %> </h5> 
                <span><%=  formatter.format(el.colors[0].price )  %></span>
              </div>
            <% }) %>
          <% } %>
        </div>

        <!-- Specification Table -->
        <% if(product.variants && product.variants.length > 0) { %>
          <div class="border-bottom mb-3">
            <h5>טווח</h5>
            <div class="d-flex justify-content-around">
              <% product.variants.forEach(el =>{ %>
                <span>עד <%= el.range %></span>
              <% }) %>
            </div>
          </div>

          <div class="border-bottom mb-3">
            <h5>סוללה</h5>
            <div class="d-flex justify-content-around">
              <% product.variants.forEach(el =>{ %>
                <span><%= el.battary %></span>
              <% }) %>
            </div>
          </div>

          <div class="border-bottom mb-3">
            <h5>זמינות</h5>
            <div class="d-flex justify-content-around">
              <% product.variants.forEach(el =>{ %>
                <span><%= el.availability %></span>
              <% }) %>
            </div>
          </div>

          <div class="mb-3">
            <h5>נוחות</h5>
            <div class="d-flex justify-content-around">
              <% product.variants.forEach(el =>{ %>
                <span> שיכוך כפול  </span>
              <% }) %>
            </div>
          </div>
        <% } %>

      </div>
    </div>
  </div>
</div>
