<script>
  document.addEventListener('DOMContentLoaded', function () {
    const sliderElement = document.querySelector('.inokimSwiper');

    if (!sliderElement || typeof Swiper === 'undefined') return;

    new Swiper(sliderElement, {
      slidesPerView: 1.2,
      spaceBetween: 16,
      centeredSlides: false,
      loop: false,
      pagination: {
        el: '.swiper-pagination',
        clickable: true,
      },
      breakpoints: {
        768: {
          slidesPerView: 1.5,
          spaceBetween: 20,
        },
        1200: {
          slidesPerView: 1.4,
          spaceBetween: 24,
        }
      }
    });
  });
</script>