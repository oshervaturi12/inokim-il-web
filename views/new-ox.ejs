<style>
.hero-content {
  position: relative;
  z-index: 2;
  max-width: 720px;
}

.hero-quick-links {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  justify-content: flex-start;
}

.hero-quick-link {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: .5em;
  /* padding: 0.85rem .8rem; */
  border-radius: 12px;
  text-decoration: none;
  color: #fff;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.16);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.18);
  transition: transform 0.25s ease, background 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  font-weight: 500;
  letter-spacing: 0.01em;
}

.hero-quick-link:hover {
  color: #fff;
  transform: translateY(-2px);
  background: rgba(255, 255, 255, 0.12);
  border-color: rgba(255, 255, 255, 0.3);
  box-shadow: 0 14px 40px rgba(0, 0, 0, 0.24);
}

.hero-quick-link-icon {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.12);
  flex-shrink: 0;
}

.hero-main-btn,
.hero-secondary-btn {
  min-height: 56px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
}

@media (max-width: 767.98px) {
  .hero-quick-links {
    flex-direction: column;
    align-items: stretch;
  }

  .hero-quick-link {
    width: 100%;
    justify-content: flex-start;
  }


  .cta-banner .btn {
    width: 100% !important;
  }
}

/* =====================================================
   HERO – OX PAGE
===================================================== */

.hero-section.ox-page {
  background: url('/optimized/ox-hero2.png') center / cover no-repeat;
  height: 100vh;
  position: relative;
  margin-top: -4em;
}

.hero-section .overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 214px;
  background: linear-gradient(180deg, #00000000 0%, #000000 100%);
}

.ox-page h6 {
  font-size: 27px;
  letter-spacing: 5.1px;
}

.ox-page h1 {
  font-size: 3.5rem;
  line-height: 3.8rem;
  letter-spacing: 0;
}

.ox-page p {
  font-size: 20px;
  letter-spacing: 0;
  margin: 0;
  padding: 0;
}

.ox-page .cta-banner {
  max-width: 400px;
}


/* =====================================================
   GHOST SHIELD SECTION
===================================================== */

.ghost-shield {
  background: #000;
}

.ghost-title {
  font-size: 3rem;
  font-weight: 500;
  color: #ff0000;
  letter-spacing: 0;
}

.ghost-shield h4 {
  font-size: 2.2rem;
}

.ghost-shield p {
  font-size: 1.7rem;
  letter-spacing: 2.32px;
}

.ghost-card {
  background: linear-gradient(145deg, #111, #1a1a1a);
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,0.05);
  transition: 0.3s ease;
}

.ghost-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 10px 30px rgba(255, 0, 0, 0.2);
}

.ghost-list li {
  position: relative;
  padding-right: 25px;
  margin-bottom: 8px;
  font-size: 0.95rem;
}

.ghost-list li::before {
  content: "";
  position: absolute;
  right: 0;
  top: 4px;
  width: 16px;
  height: 16px;
  background: url('/optimized/check.svg') center / contain no-repeat;
}


/* =====================================================
   DASHBOARD SECTION
===================================================== */

.dashboard-section {
  background: #000;
}

.dashboard-title {
  font-size: 2.6rem;
  font-weight: 700;
}

.dashboard-subtitle {
  font-size: 1.5rem;
  letter-spacing: 3px;
  opacity: 0.8;
  margin: 0;
}

.dashboard-image-wrapper {
  max-width: 1300px;
  margin: auto;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.dashboard-img {
  max-width: 900px;
  margin-top: -3rem;
  display: block;
}

/* Feature Labels (Desktop) */

.feature {
  position: absolute;
  width: 260px;
  color: #fff;
}

.feature span {
  display: inline-block;
  font-size: 1.1rem;
  font-weight: 500;
  border-bottom: 1.5px solid rgba(255,255,255,0.4);
}

.feature.left {
  left: 0;
  text-align: center;
}

.feature.right {
  right: 0;
  text-align: right;
}

.feature.left::after,
.feature.right::after {
  content: "";
  position: absolute;
  height: 1.5px;
  width: 100%;
  background: rgba(255,255,255,0.4);
}

.feature.left::after {
  top: 96%;
  right: -55%;
}

.feature.right::after {
  top: 93%;
  left: -50%;
}

.feature-1 { top: 20%; }
.feature-2 { top: 40%; }
.feature-3 { top: 60%; }
.feature-4 { top: 20%; }
.feature-5 { top: 45%; }
.feature-6 { top: 70%; }

/* Mobile Feature List */

.dashboard-mobile-features {
  max-width: 500px;
  margin: auto;
}

.mobile-item {
  padding: 18px 0;
  border-bottom: 1px solid rgba(255,255,255,0.2);
  font-size: 1rem;
}

.mobile-item:last-child {
  border-bottom: none;
}


/* =====================================================
   KIX HERO
===================================================== */

.kix-hero {
  min-height: 700px;
  background: url('/optimized/new-ox-section3.png') center right / cover no-repeat;
  position: relative;
  overflow: hidden;
}

.hero-title {
  font-size: 2.8rem;
  font-weight: 700;
}

.hero-description {
  font-size: 1.1rem;
  opacity: 0.9;
}

.hero-list li {
  position: relative;
  padding-right: 28px;
  margin-bottom: 14px;
  font-size: 1rem;
  font-weight: 500;
}

.hero-list li::before {
  content: "";
  position: absolute;
  right: 0;
  top: 4px;
  width: 16px;
  height: 16px;
  background: url('/optimized/check.svg') center / contain no-repeat;
}


/* =====================================================
   POWER SECTION
===================================================== */

.power-title {
  font-size: 2.5rem;
  font-weight: 700;
}

.power-card {
  background: #e9e9eb;
  border-radius: 12px;
  padding: 50px 20px;
  height: 100%;
  transition: 0.3s ease;
}

.power-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 15px 40px rgba(0,0,0,0.08);
}

.power-number {
  font-size: 8.5rem;
  font-weight: 400;
  color: #ff0000;
  line-height: 1;
  display: inline-block;
  width: 100%;
  position: relative;
}

.power-number .exclamation {
  display: flex;
  align-items: center;
  margin-right: 8px;
  position: relative;
}

.power-number .exclamation::before {
  content: "";
  position: absolute;
  width: 14px;
  height: 60%;
  background: rgba(0,0,0,0.08);
  right: -8px;
  top: 10%;
  border-radius: 4px;
  z-index: -1;
}

.power-text {
  margin-top: 20px;
  font-size: 1.5rem;
  font-weight: 500;
  text-align: start;
}


/* =====================================================
   CARBON SECTION
===================================================== */

.carbon-section {
  background: #000;
  padding-top: 8em !important;
}

.carbon-title {
  font-size: 3.7rem;
  font-weight: 500;
  letter-spacing: 1px;
}

.carbon-subtitle {
  font-size: 2rem;
  opacity: 0.8;
}

.carbon-image {
  max-width: 100%;
  transition: transform 0.4s ease;
}

.carbon-image:hover {
  transform: scale(1.03);
}

.carbon-list li {
  position: relative;
  padding-right: 28px;
  margin-bottom: 16px;
  font-size: 1.2rem;
  font-weight: 500;
}

.carbon-list li::before {
  content: "";
  position: absolute;
  right: 0;
  top: 4px;
  width: 16px;
  height: 16px;
  background: url('/optimized/check.svg') center / contain no-repeat;
}

.colors img {
  width: 2.4rem;
}


/* =====================================================
   CAROUSEL SECTION
===================================================== */

.carusel-section h2 {
  font-size: 2.3rem;
}

.new-ox-page .text-bg{
font-size: 95px !important;
 top: 30% !important;
}



/* FAQ SECTION */

.faq-section {
  position: relative;
  overflow: hidden;
}

.faq-header .faq-kicker {
  display: inline-block;
  font-size: 0.8rem;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.65);
}

.faq-title {
  font-size: clamp(2rem, 4vw, 3.4rem);
  font-weight: 700;
  line-height: 1.05;
  margin-bottom: 0.75rem;
}

.faq-subtitle {
  color: rgba(255, 255, 255, 0.7);
  font-size: 1rem;
}

.faq-accordion {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.faq-item {
  border: 1px solid rgba(255, 255, 255, 0.08);
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.04) 0%,
    rgba(255, 255, 255, 0.02) 100%
  );
  border-radius: 24px;
  overflow: hidden;
  backdrop-filter: blur(12px);
  transition: all 0.3s ease;
}

.faq-item:hover {
  border-color: rgba(255, 0, 0, 0.35);
  box-shadow: 0 20px 60px rgba(255, 0, 0, 0.08);
}

.faq-question {
  width: 100%;
  border: 0;
  background: transparent;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  text-align: right;
  padding: 1.4rem 1.5rem;
  font-size: 1.08rem;
  font-weight: 600;
}

.faq-question:focus {
  outline: none;
  box-shadow: none;
}

.faq-icon {
  flex-shrink: 0;
  width: 38px;
  height: 38px;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.06);
  font-size: 1.4rem;
  line-height: 1;
  transition: all 0.25s ease;
}

.faq-question:not(.collapsed) .faq-icon {
  transform: rotate(45deg);
  background: #ff1f1f;
  color: #fff;
}

.faq-answer {
  padding: 0 1.5rem 1.5rem;
}

.faq-answer p {
  margin: 0;
  color: rgba(255, 255, 255, 0.72);
  font-size: 1rem;
  line-height: 1.9;
}








@media (max-width: 768px) {
  .faq-question {
    padding: 1.15rem 1rem;
    font-size: 1rem;
  }

  .faq-answer {
    padding: 0 1rem 1.2rem;
  }

  .faq-icon {
    width: 34px;
    height: 34px;
  }
}

/* =====================================================
   RESPONSIVE
===================================================== */

@media (max-width: 992px) {




  .feature {
    display: none;
  }

  .kix-hero {
    min-height: 550px;
    background-position: center;
  }

  .hero-title {
    font-size: 2rem;
  }
}

@media (max-width: 768px) {

  .hero-section.ox-page {
    background: url('/optimized/ox-mobile5.png') center / cover no-repeat;
  }

  .new-ox-page .text-bg{
  font-size: 30px !important;
  top: 30% !important;
  }

  .hero-section .overlay {
    height: 90px;
    bottom: -2px;
  }

  .hero-section .mt-mobile {
    /* margin-top: auto;
    margin-bottom: 5em;
    text-align: center; */
            margin-bottom: auto;
        margin-top: 13em;
  }

  .hero-section .mt-mobile h6 {
    font-size: 20px;
    letter-spacing: 2.1px;
  }

  .hero-section .mt-mobile h1 {
    line-height: 43px;
    font-size: 2.5rem;
  }

  .ghost-shield {
    padding: 0 20px;
  }

  .ghost-title {
    font-size: 2rem;
  }

  .ghost-shield h4 {
    font-size: 1.7rem !important;
  }

  .ghost-shield p {
    font-size: 1.4rem;
    letter-spacing: 1.8px;
  }

  .dashboard-section {
    padding: 0 20px;
  }

  .dashboard-title {
    font-size: 2.3rem;
  }

  .dashboard-subtitle {
    letter-spacing: 1px;
  }


  .kix-hero{
    min-height: 400px;
    background: none;
    /* background: url(/optimized/ox-mobile2.png) center  / cover no-repeat; */
  }

  .power-title{
    font-size: 2rem;
  }
.power-section .row{
    padding: 0 15px;
}

.carbon-list li{
  text-align: start;
}
}

</style>


