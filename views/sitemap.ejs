<%- include("./partials/navbar.ejs", { customClass: customClass }) %>


<main id="sitemap-page" class="container py-5">
  <h1 class="text-center display-5 fw-bold mb-5">מפת האתר אינוקים</h1>
  <div class="row">
    <% sitemapEntries.forEach(category => { %>
      <div class="col-md-3 mb-4">
        <h5 class="fw-semibold pb-2"><%= category.title %></h5>
        <ul class="list-unstyled">
          <% category.links.forEach(link => { %>
            <li class="my-2">
              <a href="<%= link.url %>" class="text-decoration-none text-primary">
                <%= link.label %>
              </a>
            </li>
          <% }) %>
        </ul>
      </div>
    <% }) %>
  </div>
</main>

<%- include('./partials/footer.ejs') %>
