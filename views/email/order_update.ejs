<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <title>עדכון סטטוס הזמנה</title>
  <style>
   body {
            direction: rtl;
            font-family: Arial, sans-serif;
            text-align: right;
            background-color: #f5f5f5;
            padding: 20px;
            margin: 0;
        }

    .email-wrapper {
      background: #fff;
      border-radius: 8px;
      padding: 30px;
      max-width: 600px;
      margin: 0 auto;
      box-shadow: 0 0 15px rgba(0,0,0,0.05);
    }

    h1 {
      color: #2e7d32;
      font-size: 20px;
      margin-bottom: 10px;
    }

    .status-box {
      background-color: #e8f5e9;
      border-right: 4px solid #2e7d32;
      padding: 10px;
      font-weight: bold;
      margin: 20px 0;
    }

    ul {
      padding-right: 20px;
    }

    .info p {
      margin: 5px 0;
    }

    .footer {
      margin-top: 30px;
      font-size: 12px;
      color: #999;
      text-align: center;
    }

    .cta-button {
      display: inline-block;
      margin-top: 20px;
      padding: 10px 20px;
      background-color: #2e7d32;
      color: #fff;
      text-decoration: none;
      border-radius: 6px;
      font-weight: bold;
    }
  </style>
</head>
<body style="direction: rtl; font-family: Arial, sans-serif; background-color: #f5f5f5; padding: 20px; color: #333;">

    <% const orderStatusMap = { 
        "processing": "בעיבוד",
        "shipped": "נשלח",
        "delivered": "נמסר",
        "cancelled": "בוטל"
    } %>
  
    <div class="email-wrapper" style="background: #fff; border-radius: 8px; padding: 30px; max-width: 600px; margin: 0 auto; box-shadow: 0 0 15px rgba(0,0,0,0.05);">
      <h1 style="color: #2e7d32; font-size: 20px; margin-bottom: 10px;">עדכון סטטוס להזמנה</h1>
  
      <p>הסטטוס של הזמנה מספר <strong><%= data._id %></strong> עודכן.</p>
  
      <div class="status-box" style="background-color: #e8f5e9; border-right: 4px solid #2e7d32; padding: 10px; font-weight: bold; margin: 20px 0;">
        סטטוס נוכחי: <%= orderStatusMap[data.orderStatus] || 'לא ידוע' %>
      </div>
  
      <div class="info">
        <p><strong>שם לקוח:</strong> <%= data.contactInfo?.firstName || '---' %> <%= data.contactInfo?.lastName || '' %></p>
        <p><strong>אימייל:</strong> <%= data.contactInfo?.email || '---' %></p>
        <p><strong>טלפון:</strong> <%= data.contactInfo?.phone || '---' %></p>
        <p><strong>סכום הזמנה:</strong> ₪<%= data.totalPrice %></p>
        <p><strong>שונה בתאריך:</strong> <%= data.lastStatusModifiedDate ? new Date(data.lastStatusModifiedDate).toLocaleString('he-IL') : '---' %></p>
      </div>
  
      <% if (data.items && data.items.length > 0) { %>
        <h3>פרטי מוצרים:</h3>
        <ul>
          <% data.items.forEach(item => { %>
            <li style="margin-bottom: 8px;">
              <strong><%= item.prdName %></strong>
              <% if (item.color?.name) { %> | צבע: <%= item.color.name %> <% } %>
              <% if (item.sku) { %> | SKU: <%= item.sku %> <% } %>
              | כמות: <%= item.quantity %>
              <% if (item.serialNumber) { %> | מס׳ סידורי: <%= item.serialNumber %> <% } %>
            </li>
          <% }) %>
        </ul>
      <% } %>
  
      <a href="https://il.inokim.com/admin/orders/<%= data._id %>" class="cta-button" style="display: inline-block; margin-top: 20px; padding: 10px 20px; background-color: #2e7d32; color: #fff; text-decoration: none; border-radius: 6px; font-weight: bold;">
        לצפייה בהזמנה במערכת
      </a>
  
      <div class="footer" style="margin-top: 30px; font-size: 12px; color: #999; text-align: center;">
        נשלח אוטומטית ממערכת INOKIM
      </div>
    </div>
  </body>
  
</html>
