<section class="specs p-3">
    <div class="container text-white mt-3 py-0 py-md-5">
        <h2 class="mb-4">מפרט <%= product.name %></h2>
      
        <% if (product.specs && product.specs.length > 0) { %>
          <% product.specs.forEach(spec => { %>
            <div class="spec-section pb-4 mb-5">
              <!-- Section Title -->
              <div class="mb-0 mb-md-4">
                <h5 class="m-0"><%= spec.category %></h5>
              </div>
      
              <% if (spec.category === 'מידות' && spec.image) { %>
                <!-- Special Layout for מידות -->
                <div class="row align-items-center">
                  <!-- Spec Items -->
                  <div class="col-12 col-md-8 order-2 order-md-1">
                    <div class="row">
                      <% spec.items.forEach(item => { %>
                        <div class="col-6 col-md-6 d-flex flex-column justify-content-center align-items-start pb-3">
                          <span class="fw-bold mb-2"><%= item.label %></span>
                          <strong><%= item.value %></strong>
                        </div>
                      <% }) %>
                    </div>
                  </div>
      
                  <!-- Image on the side -->
                  <div class="col-12 col-md-4 text-center order-1 order-md-2">
                    <%- optimizeImage(`${spec.image}`, `${spec.category}`, 'img-fluid') %>

                    <!-- <img src="<%= spec.image %>" alt="<%= spec.category %>" class="img-fluid" style="max-width: 100%;"> -->
                  </div>
                </div>
              <% } else { %>
                <!-- General Layout for Other Specs -->
                <% if (spec.image) { %>
                  <div class="spec-image text-center mb-4">
                    <%- optimizeImage(`${spec.image}`, `${spec.category}`, 'img-fluid') %>

                    <!-- <img src="<%= spec.image %>" alt="<%= spec.category %>" class="img-fluid" style="max-width: 50%;"> -->
                  </div>
                <% } %>
      
                <% if (spec.items && Array.isArray(spec.items)) { %>
                  <div class="row">
                    <% spec.items.forEach(item => { %>
                      <div class="col-6 col-md-3 d-flex flex-column justify-content-center align-items-start pb-3">
                        <span class="fw-bold mb-2"><%= item.label %></span>
                        <strong><%= item.value %></strong>
                      </div>
                    <% }) %>
                  </div>
                <% } else { %>
                  <p class="text-center text-muted">לא נמצאו פריטים במפרט זה.</p>
                <% } %>
              <% } %>
            </div>
          <% }) %>
        <% } else { %>
          <p class="text-center text-muted">לא קיימים מפרטים זמינים עבור מוצר זה.</p>
        <% } %>

      </div>
      
    
    
    
</section>



 
<% if(!hasInventory) { %>
  <section class="specs p-3">
    <div class="container mb-5">
      <div class="text-center">
        <h2>קבלו עדכונים</h2>
        <p>נציג אינוקים רשמי ייצור אתכם קשר לגבי חזרת המוצר למלאי או מציאת  <%= product.name   %> יד שניה</p>
      </div>
  
      <form action="" id="secondHand" class="dynamic-form">
        <div class="row g-3 g-md-5 mb-3">
          <div class="col-12 col-md-6">
            <label class="form-label" for="fullName">שם מלא</label>
            <input type="text" name="fullName" class="form-control">
          </div>
          <div class="col-12 col-md-6">
            <label form="email" class="form-label">אימייל</label>
            <input type="text" name="email" class="form-control">
          </div>
          <div class="col-12 col-md-6">
            <label class="form-label" for="phone">מספר טלפון</label>
            <input type="tel" name="phone" class="form-control" id="">
          </div>
          <div class="col-12 col-md-6">
            <label class="form-label" for="location">עיר</label>
            <input type="text" name="location" class="form-control">
          </div>
          <input type="hidden" name="type" value="secondHand" id="">
          <small>*אני מסכים שייצרו איתי קשר לגבי מוצרי אינוקים, כולל באמצעות שיחות אוטומטיות או הודעות טקסט. אני מבין ומסכים להודעת הפרטיות ולתנאי השימוש של אינוקים.      </small>
        </div>
      <div class="w-100 text-center">
        <button type="submit" class="btn btn-primary">שלח</button>
      </div>
      </form>
    </div>


  </section>
<% } %>

<section class="overview-header">
