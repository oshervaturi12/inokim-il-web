<%- include("./partials/announcement.ejs", { 
    text: `${hasInventory ? ` ${product.name} קונים רק באינוקים! `: "המוצר לא זמין כרגע במלאי"}`, 
    buttonLink:  `${!hasInventory ? "#secondHand": `/products/${product.slug}`}`  , 
    buttonText: `${hasInventory ? "קנה עכשיו" : "מצא מלאי"}`,
    isSale: false
}) %>
<%- include("./partials/navbar.ejs", { customClass: customClass }) %>

<% 
  const basePrice = product.price || (product.variants?.[0]?.colors?.[0]?.price || 0);
  const secondPrice = product.variants?.[1]?.colors?.[0]?.price || null;
%>


<main id="top-app">
    <div id="wd-product-overview">
        <div class="section-overview" style="--background: url('<%= `${s3path}${product.overviewImage}` %>')">

        

        <div class="text">
    
            <div class="logo">
                <%- product.logoSvg %>
    
            </div>
    
            <div class="info">
    
                <div>
                    <h2> <%= product.overviewSubtitle  %> </h2>
                    <p>
                        <%= product.title  %>
                    </p>
                </div>
    
                <div><div class="wd-extra-shipping-details-wrapper">

                    <% if(product && product.mainInfo && product.mainInfo.length > 0 ) { %>
                        <% product.mainInfo.forEach(el =>{ %>
                            <div class="wd-extra-shipping-details-block">
                                    
                                <div class="wd-extra-shipping-details__icon">
                       
                                    <img src="<%= el.img  %>" alt="">
                                </div>
                            
                            
                                <div class="wd-extra-shipping-details__text">
                                    
                                        <div class="wd-extra-shipping-details__title">
                                             <%=el.key  %>
                                        </div>
                                    
                                    
                                        <div class="wd-extra-shipping-details__desc">
                                            <%=el.value  %>
                                        </div>
                                    
                                </div>
                            
                        </div>
                      <%  }) %>

                   <% }  %>
                            

                            
                        </div>
                    </div>
    
                <div class="price-item">
                    <div class="price">

                      <%= formatter.format(basePrice) %> 
                      <%= secondPrice ? " / " + formatter.format(secondPrice) : "" %>
                       
    
                    </div>
          
                </div>
    
            </div>
    
    
        </div>
    
    </div>


    <div class="container p-5">
          <div class="row">


                        <% if(product && product.mainInfo && product.mainInfo.length > 0 ) { %>
                        <% product.mainInfo.forEach(el =>{ %>



                              <div class="col-12 col-md-4 border-bottom border-md-start text-center">
                                
                                <strong class="overviewSpec">   <%=el.value  %></strong>
                        <span class="d-block">   <%=el.key  %></span>
                              </div>

                      <%  }) %>

              

                   <% }  %>



    </div>

    </div>


    <% if(product.overviewVideo) { %>
        <section class="info">
            <div class="video-container">
         

                <video
                  class="info-video"
                  preload="metadata"
                  width="100%"
                  height="auto"
                  muted
                  autoplay
                  loop
                  playsinline
                  preload="none"
                  poster="<%= s3path  %>/optimized/bgVideo.webp"
                  >
                  <source data-src="<%= `${s3path}${product.overviewVideo}`%>" type="video/mp4">
                  Your browser does not support the video tag.
                </video>
          
                <div class="video-overlay-dark"></div>
          
                <div class="video-overlay">
                  <h2><%= product.title  %> </h2>
                  <a href="/products/<%= product.slug  %>" class="btn btn-outline">הזמינו עכשיו</a>
                </div>
              </div>
        
            </section>
   <% } %>
 
      


        <section class="overview-content-blocks">
      <% if(product.contentBlocks && product.contentBlocks.length > 0) { %>
    
      <% product.contentBlocks.forEach((block, index) => { %>
        <% if (block.type === 'imageWithText') { %>
          <div class="container py-5">
            <div class="row align-items-center <%= block.imagePosition === 'left' ? 'flex-row-reverse' : '' %>">
              
              <!-- Image -->
              <div class="col-12 col-md-6 text-center mb-4 mb-md-0">
                <div class="img-box">
                  <img src="<%= `${s3path}${block.image}` %>" alt="<%= block.title %>" class="img-fluid rounded shadow-sm">
                </div>
              </div>
    
              <!-- Text -->
              <div class="col-12 col-md-6 text-md-end text-center text-light pe-md-5 ps-md-5">
                <h2 class="mb-3"><%= block.title %></h2>
                <p style="line-height: 1.8;"><%= block.content %></p>
              </div>
    
            </div>
          </div>
        <% } %>
      <% }) %>
    
      <% } %>
    </section>

