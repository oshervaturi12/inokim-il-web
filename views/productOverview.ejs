<!-- Bootstrap Tabs -->
<ul class="nav nav-tabs" id="variantTabs" role="tablist">
  <% product.variants.forEach((variant, index) => { %>
      <li class="nav-item" role="presentation">
          <button 
              class="nav-link <%= index === 0 ? 'active' : '' %>" 
              id="variant-tab-<%= index %>" 
              data-bs-toggle="tab" 
              data-bs-target="#variant-content-<%= index %>" 
              type="button" 
              role="tab" 
              aria-controls="variant-content-<%= index %>" 
              aria-selected="<%= index === 0 ? 'true' : 'false' %>"
          >
              <%= variant.subModel %>
          </button>
      </li>
  <% }) %>
</ul>
</div>
<!-- Tab Content -->
<div class="tab-content" id="variantTabsContent">
  <% product.variants.forEach((variant, index) => { %>
      <div 
          class="tab-pane fade mb-5 <%= index === 0 ? 'show active' : '' %>" 
          id="variant-content-<%= index %>" 
          role="tabpanel" 
          aria-labelledby="variant-tab-<%= index %>"
      >
          <div class="line">
              <div>
                  <div class="title">
                      מחיר רגיל
                  </div>
                  <div class="price">
                      <span> <%= formatter.format(variant.colors[0].price) %> </span>
                  </div>
              </div>

              <div>
                  <div class="title">
                      תשלום חודשי
                  </div>
                  <div class="price">
                      <span> <%= formatter.format(variant.colors[0].price / 36) %> ש״ח/לחודש</span>
                  </div>
              </div>
          </div>
      </div>
  <% }) %>

  <a href="#" class="btn btn-light w-50">קנה עכשיו</a>

</div>

    
    
